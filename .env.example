# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Template for local development secrets
#
# COPY this file to  .env  and fill in real values.
# The  .env  file is in  .gitignore  and must NEVER be committed.
# In production, inject secrets via your cloud provider's secrets manager.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
# NEVER hard-code this value anywhere in source code.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Webhook HMAC secret ────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SEPSIS_WEBHOOK_SECRET=REPLACE_ME_HEX_SECRET

# ── Encrypted config key (optional) ──────────────────────────────────────────
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SEPSIS_CONFIG_KEY=REPLACE_ME_FERNET_KEY

# ── Server behaviour ──────────────────────────────────────────────────────────
SEPSIS_ENV=development           # set to "production" to disable /docs
SEPSIS_FORCE_HTTPS=false         # set to "true" in production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
SEPSIS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ── Database (Phase 1) ────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sepsis_vitals
# All credentials must be injected via env — never in connection strings in code.
