# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Copy to .env and fill in values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── JWT (RS256) — generate with openssl ───────────────────────────────────────
# openssl genrsa -out jwt_private.pem 2048
# openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Then paste single-line versions (replace newlines with \n):
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sepsis:REPLACE_ME@localhost:5432/sepsis_vitals
DB_SSL=disable   # set to "require" in production

# ── Redis (sessions + rate-limit counters) ────────────────────────────────────
REDIS_URL=redis://:REPLACE_ME@localhost:6379/0
REDIS_PASSWORD=REPLACE_ME

# ── Encryption keys ───────────────────────────────────────────────────────────
# AES-256 key for patient PII (32 bytes, base64-encoded):
# python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
SEPSIS_PII_KEY=REPLACE_ME_BASE64_32_BYTES

# Fernet key for config values:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SEPSIS_CONFIG_KEY=REPLACE_ME_FERNET_KEY

# ── Webhook ───────────────────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
SEPSIS_WEBHOOK_SECRET=REPLACE_ME_HEX_SECRET

# ── Auth & Server ─────────────────────────────────────────────────────────────
SEPSIS_AUTH_ENABLED=true       # Auth is ON by default; set "false" for local dev
SEPSIS_API_KEYS={"your-api-key-here": {"role": "system_admin", "user": "admin"}}
SEPSIS_JWT_SECRET=REPLACE_ME_WITH_RANDOM_SECRET
SEPSIS_ENTERPRISE_LLM=false    # LLM copilot OFF by default; requires signed BAA with Anthropic
SEPSIS_ENV=development         # "production" disables /docs and /openapi.json
SEPSIS_FORCE_HTTPS=false       # true in production
SEPSIS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
LOG_LEVEL=INFO

# ── Docker compose extras ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=REPLACE_ME
GRAFANA_PASSWORD=REPLACE_ME
